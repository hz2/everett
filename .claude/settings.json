{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "nix develop --command cargo clippy --all-features -- -D warnings",
            "timeout": 120,
            "statusMessage": "running clippy..."
          }
        ]
      }
    ]
  }
}
